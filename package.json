{
  "name": "rollup-plugin-three-minify",
  "description": "Minify Three.js shader code, and remove redundant code",
  "keywords": [
    "rollup-plugin",
    "rolldown-plugin",
    "vite-plugin",
    "three",
    "minify"
  ],
  "author": "brybrant",
  "license": "GPL-3.0-only",
  "version": "1.0.2",
  "type": "module",
  "types": "./dist/index.d.mts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "default": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      },
      "require": {
        "default": "./dist/index.cjs",
        "types": "./dist/index.d.cts"
      }
    }
  },
  "files": [
    "./dist"
  ],
  "scripts": {
    "build": "tsdown",
    "rollup": "env ROLL=up node ./test/rollx.js",
    "rolldown": "env ROLL=down node ./test/rollx.js",
    "vite": "node ./test/vite.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brybrant/rollup-plugin-three-minify.git"
  },
  "devDependencies": {
    "@brybrant/eslint-config": "^1.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rollup": "^4.60.4",
    "rollup-plugin-three-minify": ".",
    "three": "^0.184.0",
    "tsdown": "^0.22.0",
    "vite": "^7.3.3"
  },
  "peerDependencies": {
    "three": ">= 0.135.0"
  }
}
